# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database Configuration (PostgreSQL)
DB_HOST=pg-xxxxx.aivencloud.com
DB_PORT=22082
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your_password_here
DB_SSL=true
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=30000

# Redis Configuration
REDIS_HOST=redis-xxxxx.aivencloud.com
REDIS_PORT=18356
REDIS_PASSWORD=your_password_here
REDIS_DB=0
REDIS_TLS=true

# LLM Provider Configuration
# NVIDIA NIM (Primary)
NIM_API_KEY=your_nvidia_nim_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com
NIM_MODEL=nvidia/mixtral-8x7b-instruct-v0.1
NIM_REQUEST_TIMEOUT=30000

# Fallback LLM
FALLBACK_LLM_KEY=your_fallback_api_key_here
FALLBACK_LLM_BASE_URL=https://api.openai.com/v1
FALLBACK_LLM_MODEL=gpt-3.5-turbo
FALLBACK_LLM_TIMEOUT=30000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
TOKEN_RETRY_BACKOFF_MULTIPLIER=2

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_MAX_CONNECTIONS=1000

# Worker Configuration
WORKER_CONCURRENCY=1
WORKER_MAX_RETRIES=3
WORKER_BACKOFF_MULTIPLIER=2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_FORMAT=json
LOG_FILE=logs/application.log
LOG_ERROR_FILE=logs/error.log
LOG_LEVEL=debug

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
